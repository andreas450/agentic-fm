<?xml version="1.0"?>
<fmxmlsnippet type="FMObjectList">
  <Step enable="True" id="220" name="Generate Response from Model">
    <Option state="True"/>
    <SelectAll state="True"/>
    <Stream state="True"/>
    <Set state="True"/>
    <LinkAvail state="True"/>
    <Restore state="True"/>
    <UniversalPathList type="Reference"/>
    <Text/>
    <Field>$response</Field>
    <LLMRequestWithTools>
      <AccountName>
        <Calculation><![CDATA["account"]]></Calculation>
      </AccountName>
      <Model>
        <Calculation><![CDATA["model"]]></Calculation>
      </Model>
      <UserPrompt>
        <Calculation><![CDATA["user-prompt"]]></Calculation>
      </UserPrompt>
      <Instructions>
        <Calculation><![CDATA["Instructions"]]></Calculation>
      </Instructions>
      <Field type="Messages">$Messages</Field>
      <SlidingWindowVariable IncludeToolCalls="1">$Save_Message_History_To</SlidingWindowVariable>
      <SlidingWindowMessageCount>
        <Calculation><![CDATA[$count]]></Calculation>
      </SlidingWindowMessageCount>
      <SlidingWindowVariableRepetition>
        <Calculation><![CDATA[1]]></Calculation>
      </SlidingWindowVariableRepetition>
      <ToolDefinitions>
        <Calculation><![CDATA["Tool_Definitions"]]></Calculation>
      </ToolDefinitions>
      <Field type="ToolCalls">$Tool_Calls_from_Model</Field>
      <Temperature>
        <Calculation><![CDATA["Temperature"]]></Calculation>
      </Temperature>
      <Parameters>
        <Calculation><![CDATA["Parameters"]]></Calculation>
      </Parameters>
      <WebScript>
        <ObjectName>
          <Calculation><![CDATA[$object_name]]></Calculation>
        </ObjectName>
        <FunctionName>
          <Calculation><![CDATA[$function_name]]></Calculation>
        </FunctionName>
        <WebScriptParameters Count="2">
          <P>
            <Calculation><![CDATA[$parameter1]]></Calculation>
          </P>
          <P>
            <Calculation><![CDATA[$parameter2]]></Calculation>
          </P>
        </WebScriptParameters>
      </WebScript>
    </LLMRequestWithTools>
  </Step>
</fmxmlsnippet>
